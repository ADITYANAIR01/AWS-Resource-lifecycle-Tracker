# =============================================================================
# AWS Resource Lifecycle Tracker — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# NEVER use real values in this file — it is committed to the repo
# =============================================================================

# -----------------------------------------------------------------------------
# PHASE 1 — Database (RDS in production / local postgres in dev)
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=lifecycle_tracker
DB_USER=trackeradmin
DB_PASSWORD=CHANGE_ME_NEVER_COMMIT_REAL_PASSWORD

# -----------------------------------------------------------------------------
# PHASE 1 — AWS (only needed for local dev — EC2 uses IAM Role in production)
# -----------------------------------------------------------------------------
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_ACCOUNT_ID=123456789012

# -----------------------------------------------------------------------------
# PHASE 1 — SNS
# -----------------------------------------------------------------------------
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:lifecycle-tracker-alerts
ALERT_EMAIL=your-email@example.com

# -----------------------------------------------------------------------------
# PHASE 6 — Dashboard Auth (mandatory — app refuses to start without this)
# -----------------------------------------------------------------------------
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# -----------------------------------------------------------------------------
# PHASE 0 — Flask
# -----------------------------------------------------------------------------
FLASK_DEBUG=false

# -----------------------------------------------------------------------------
# PHASE 3 — Poller settings
# -----------------------------------------------------------------------------
POLL_INTERVAL_MINUTES=60

# -----------------------------------------------------------------------------
# PHASE 5 — Alert thresholds
# -----------------------------------------------------------------------------
ALERT_EC2_RUNNING_DAYS=30
ALERT_EC2_STOPPED_DAYS=7
ALERT_EBS_UNATTACHED_DAYS=7
ALERT_EBS_SNAPSHOT_AGE_DAYS=60
ALERT_RDS_STOPPED_DAYS=7
ALERT_RDS_SNAPSHOT_AGE_DAYS=30
ALERT_IAM_INACTIVE_DAYS=90
ALERT_CW_ALARM_STALE_DAYS=7
REQUIRED_TAGS=Owner,Project,Environment