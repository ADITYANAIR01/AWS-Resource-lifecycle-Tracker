# =============================================================================
# AWS Resource Lifecycle Tracker — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# NEVER use real values in this file — it is committed to the repo
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (RDS in production / local postgres in dev)
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=lifecycle_tracker
DB_USER=trackeradmin
DB_PASSWORD=CHANGE_ME_NEVER_COMMIT_REAL_PASSWORD

# ----------------------------------------------------------------------------
# S3 SNAPSHOT BUCKET NAME
S3_SNAPSHOT_BUCKET=lifecycle-tracker-snapshots-ACCOUNT_ID

# -----------------------------------------------------------------------------
# AWS REGION
# -----------------------------------------------------------------------------
AWS_REGION=ap-south-1

# -----------------------------------------------------------------------------
# AWS CREDENTIALS
# On EC2: leave these as-is — IAM Role provides credentials automatically
# Local dev only: replace with real credentials from AWS Console
# NEVER commit real credentials
# Uncomment AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY for local development with real credentials
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_ACCOUNT_ID=123456789012

# -----------------------------------------------------------------------------
# SNS ALERTS
# Find ARN: AWS Console → SNS → Topics → lifecycle-tracker-alerts → copy ARN
# -----------------------------------------------------------------------------
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:lifecycle-tracker-alerts
ALERT_EMAIL=your-email@example.com

# -----------------------------------------------------------------------------
# DASHBOARD AUTH
# DASHBOARD_PASSWORD is mandatory — app will warn if not set
# -----------------------------------------------------------------------------
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# -----------------------------------------------------------------------------
# FLASK
# Never set FLASK_DEBUG=true in production
# -----------------------------------------------------------------------------
FLASK_DEBUG=false

# -----------------------------------------------------------------------------
# POLLER
# -----------------------------------------------------------------------------
POLL_INTERVAL_MINUTES=60

# Tag compliance alerts — disabled by default (opt-in)
# Set to true to alert on resources missing required tags
# Usually tags are optional and not everyone uses them, so we keep this disabled by default to avoid alert fatigue.
ALERT_TAGS_ENABLED=false

# -----------------------------------------------------------------------------
# ALERT THRESHOLDS — all configurable without touching code
# -----------------------------------------------------------------------------
ALERT_EC2_RUNNING_DAYS=30
ALERT_EC2_STOPPED_DAYS=7
ALERT_EBS_UNATTACHED_DAYS=7
ALERT_EBS_SNAPSHOT_AGE_DAYS=60
ALERT_RDS_STOPPED_DAYS=7
ALERT_RDS_SNAPSHOT_AGE_DAYS=30
ALERT_IAM_INACTIVE_DAYS=90
ALERT_CW_ALARM_STALE_DAYS=7
REQUIRED_TAGS=Owner,Project,Environment